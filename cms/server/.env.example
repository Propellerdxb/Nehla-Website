# Copy to .env and fill in.

PORT=4000

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3310
DB_USER=root
DB_PASSWORD=
DB_NAME=nehla_cms

# JWT signing secret (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Where uploaded images are publicly served from. Used to build absolute URLs
# stored in the DB. e.g. http://localhost:4000 in dev.
PUBLIC_BASE_URL=http://localhost:4000

# CORS origins allowed to call the API (comma-separated). The Vite public site
# and the cms/admin Vite app both need to be listed in dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178,http://localhost:5179
